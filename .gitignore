# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log
yarn-error.log
*.log

# IDEs and editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# Angular
.angular/

# Misc
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# System files
.DS_Store
Thumbs.db

# Environment secrets
.env
.env.*

# Runtime-generated env config (template is committed, this is not)
public/assets/env.js

# Agent / skill tooling artifacts
.agents/
.claude/
.playwright/
.playwright-cli/
skills-lock.json

# Markdown docs (keep only README.md)
*.md
!README.md

# Playwright CLI session artifacts (screenshots/snapshots at root)
/*.png
/admin-*.yml
/create-*.yml
/dialog*.yml
/events-*.yml
/event-*.yml
/filter-*.yml
/login-*.yml
/nav-*.yml
/occupancy*.yml
/reservations-*.yml
/reserve-*.yml
